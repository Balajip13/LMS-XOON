## Server environment variables (copy to .env)
NODE_ENV=development
PORT=5000

# Client / CORS
CLIENT_URL=http://localhost:5173

# Database
MONGO_URI=mongodb://localhost:27017/xoon_lms

# Auth
JWT_SECRET=replace_with_a_strong_random_secret
JWT_EXPIRE=30d

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id_here

# Cloudinary (optional, for uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# (Optional alternative supported by Cloudinary SDK)
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUDINARY_CLOUD_NAME

# SMTP (optional, for emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password
SMTP_SECURE=false
FROM_EMAIL=your_email@example.com
FROM_NAME=Xoon LMS
PLATFORM_NAME=Xoon LMS

# Payments (Razorpay)
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Security / rate limits (optional)
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
EMAIL_RATE_LIMIT=5

